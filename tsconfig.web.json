{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@domain": ["src/domain/index.ts"],
      "@domain/*": ["src/domain/*"],
      "@engine": ["src/engine/index.ts"],
      "@engine/*": ["src/engine/*"],
      "@data": ["src/data/index.ts"],
      "@data/*": ["src/data/*"],
      "@calibrate": ["src/calibrate/index.ts"],
      "@calibrate/*": ["src/calibrate/*"],
      "@render2d": ["src/render2d/index.ts"],
      "@render2d/*": ["src/render2d/*"],
      "@render3d": ["src/render3d/index.ts"],
      "@render3d/*": ["src/render3d/*"],
      "@renderer/*": ["src/renderer/*"]
    }
  },
  "include": [
    "src/renderer/**/*",
    "src/domain/**/*",
    "src/engine/**/*",
    "src/data/**/*",
    "src/calibrate/**/*",
    "src/render2d/**/*",
    "src/render3d/**/*",
    "src/worker/**/*"
  ]
}
